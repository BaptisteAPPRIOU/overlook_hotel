# Copy this file to .env.recette for local recette runs.
# Do not commit .env.recette.

RECETTE_POSTGRES_DB=overlook_hotel_recette
RECETTE_POSTGRES_USER=postgres
RECETTE_POSTGRES_PASSWORD=replace_with_a_local_recette_password

SPRING_SECURITY_USER_NAME=recette
SPRING_SECURITY_USER_PASSWORD=replace_with_a_local_recette_admin_password

# Minimum 32 characters for HS256.
APP_JWT_SECRET=replace_with_a_secret_key_of_at_least_32_characters
APP_JWT_EXPIRATION_MS=86400000

# Keep false for a production-like empty database.
# Set true only when you need local demo data.
APP_SEED_ENABLED=false
