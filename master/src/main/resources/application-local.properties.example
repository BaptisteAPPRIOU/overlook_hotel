# Copy this file to application-local.properties (in the same directory).
# This file is ignored by Git.

spring.datasource.url=jdbc:postgresql://localhost:5432/overlookhoteldb
spring.datasource.username=postgres
spring.datasource.password=your_db_password

spring.security.user.name=admin
spring.security.user.password=your_admin_password

app.seed.enabled=true

# Minimum 32 characters for HS256
app.jwt.secret=replace_with_a_secret_key_of_at_least_32_characters
app.jwt.expiration-ms=86400000
